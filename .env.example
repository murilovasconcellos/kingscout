# Supabase — projeto do KINGSCOUT
# Copie este arquivo para ".env.local" e preencha com os valores reais
# do seu projeto Supabase (Project Settings > API).

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon/public) do projeto Supabase.
# Segura para expor no cliente — a segurança real vem do Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
